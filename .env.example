# ============================================================
# .env.local
# ============================================================
# IMPORTANTE: Este archivo NUNCA debe subirse a GitHub.
# Contiene datos secretos (contraseñas, claves de API).
# Ya está en el .gitignore por defecto.
#
# Copia este archivo como ".env.local" y rellena los valores reales.
# ============================================================

# ── Base de datos ──────────────────────────────────────────
# PostgreSQL local (para desarrollo):
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/eternal_beauty"
#
# PostgreSQL en la nube (para producción, opciones recomendadas):
# - Supabase (gratis): https://supabase.com
# - Neon (gratis): https://neon.tech
# - Railway: https://railway.app
#
# Ejemplo con Supabase:
# DATABASE_URL="postgresql://postgres:[tu-password]@db.[tu-proyecto].supabase.co:5432/postgres"

# ── WhatsApp ───────────────────────────────────────────────
# Número de la dueña del salón (con código de país, sin el +)
WHATSAPP_NUMBER="50765991047"

# ── Configuración del sitio ────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Eternal Beauty Studio"
NEXT_PUBLIC_SITE_URL="https://eternalbeauty.pa"

# ── Email (para notificaciones, usar en el futuro) ─────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="tu-email@gmail.com"
# SMTP_PASS="tu-contraseña-de-aplicación"
# SALON_EMAIL="eternalbeauty@gmail.com"
